  <Target Name="EnsureNuGetPackageBuildImports" BeforeTargets="PrepareForBuild">
    <PropertyGroup>
      <ModInfoPath>$(ProjectDir)ModInfo.cs</ModInfoPath>
      <ManifestPath>$(ProjectDir)Thunderstore\TTS-Company\manifest.json</ManifestPath>
    </PropertyGroup>
    <ReadLinesFromFile File="$(ModInfoPath)">
      <Output TaskParameter="Lines" ItemName="ModInfoLines" />
    </ReadLinesFromFile>
    <ReadLinesFromFile File="$(ManifestPath)">
      <Output TaskParameter="Lines" ItemName="ManifestLines" />
    </ReadLinesFromFile>
    <PropertyGroup>
      <ModInfoText>@(ModInfoLines, '%0A')</ModInfoText>
      <ManifestText>@(ManifestLines, '%0A')</ManifestText>
      <RawVersion>$([System.Text.RegularExpressions.Regex]::Match($(ModInfoText), `(?&lt;=modVersion\s*=\s*")[^"\r\n]*`))</RawVersion>
      <ManifestVersion>$([System.Text.RegularExpressions.Regex]::Match($(RawVersion), `^\d+\.\d+\.\d+`))</ManifestVersion>
      <Pattern>(?&lt;="version_number"\s*:\s*")[^"\r\n]*(?=")</Pattern>
      <UpdatedManifest>$([System.Text.RegularExpressions.Regex]::Replace($(ManifestText), $(Pattern), $(ManifestVersion)))</UpdatedManifest>
    </PropertyGroup>
    <WriteLinesToFile File="$(ManifestPath)" Lines="$(UpdatedManifest)" Overwrite="true" Encoding="UTF-8" />
    <Message Importance="High" Text="[TTSCompany] Extracted Version $(ManifestVersion) from ModInfo.cs and updated manifest.json!" />
  </Target>
